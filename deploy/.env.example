# ──────────────────────────────────────────────────────
#  AVATAR Agent — 环境变量模板
#  使用方法: cp .env.example .env && nano .env
# ──────────────────────────────────────────────────────

# 数据库连接
DATABASE_URL=file:/app/db/custom.db

# 域名 (没有域名留空 localhost)
DOMAIN=localhost

# 应用端口
PORT=3000

# 运行环境
NODE_ENV=production

# 默认 AI 模型
DEFAULT_MODEL=deepseek-chat

# ════════════════════════════════════════════════════════════
#  登录认证 (网站访问需登录)
# ════════════════════════════════════════════════════════════
APP_USERNAME=piaoshu
APP_PASSWORD=changeme

# NextAuth JWT 签名密钥 (生成: openssl rand -base64 32)
NEXTAUTH_SECRET=please-change-this-to-a-random-32-byte-string

# NextAuth 回调 URL (你的域名)
NEXTAUTH_URL=http://localhost

# ════════════════════════════════════════════════════════════
#  AI 后端配置 - 多后端适配器
# ════════════════════════════════════════════════════════════
#  对话(文字)     | DEEPSEEK_API_KEY      | 必填
#  网络搜索       | 无需 Key              | DuckDuckGo 兜底
#  图像/VLM/TTS   | ZHIPU 或 OPENAI       | 至少一个
#  ASR 语音识别   | OPENAI                | 需要 OpenAI
# ════════════════════════════════════════════════════════════

# DeepSeek - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 智谱 AI - https://open.bigmodel.cn/usercenter/apikeys
# 格式: id.secret
ZHIPU_API_KEY=

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 其他
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Bot 连接 ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 飞书 Bot
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
